# ── Required ───────────────────────────────────────────────────────────────
# This file documents every environment variable used by AutoApply AI.
# Copy it to .env and fill in the values before running the stack.
#
#   cp .env.example .env
#
# NEVER commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────
# PostgreSQL credentials — must be set or docker-compose will fail to start.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme_use_a_strong_password
POSTGRES_DB=hiretrack
DATABASE_URL=postgresql+asyncpg://postgres:changeme_use_a_strong_password@localhost:5432/hiretrack

# ── Cache / Queue ─────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Application ───────────────────────────────────────────────────────────
ENVIRONMENT=development   # development | staging | production
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:5173","http://localhost:8501"]

# ── LLM Providers (at least one required) ────────────────────────────────
LLM__PROVIDER=groq        # groq | openai | gemini | openrouter
LLM__GROQ_API_KEY=
LLM__OPENAI_API_KEY=
LLM__GEMINI_API_KEY=
LLM__OPENROUTER_API_KEY=

# ── Job Discovery ─────────────────────────────────────────────────────────
EXA_API_KEY=

# ── Streamlit Dashboard ───────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000/api/v1
